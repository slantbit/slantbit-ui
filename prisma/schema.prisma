
generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}



datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────



enum Role {
  USER
  ADMIN
}



model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  avatarUrl     String?
  password      String?

  isActive      Boolean       @default(true)
  isVerified    Boolean       @default(false)
  verifyToken   String?
  verifyTokenExpiry DateTime?

  resetToken        String?
  resetTokenExpiry  DateTime?

  role          Role          @default(USER)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  subscription  Subscription?

  // NextAuth required fields
  accounts      Account[]
  sessions      Session[]
}

// NextAuth tables — required
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────
model Subscription {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Razorpay IDs
  razorpaySubId       String?            @unique  // sub_xxxxxxxxxx
  razorpayCustomerId  String?                     // cust_xxxxxxxxxx

  plan                Plan               @default(MONTHLY)
  status              SubscriptionStatus @default(PENDING)

  // Dates
  startDate           DateTime?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?          // subscription kab khatam hogi
  cancelledAt         DateTime?          // cancel kiya toh kab

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  payments            Payment[]
}

enum Plan {
  MONTHLY
  YEARLY                                 // baad mein add kar sakte ho
}

enum SubscriptionStatus {
  PENDING     // created but payment not done
  ACTIVE      // payment successful, access milega
  CANCELLED   // user ne cancel kiya, currentPeriodEnd tak access rahega
  EXPIRED     // period khatam, access nahi
  PAUSED      // Razorpay pause event
}

// ─────────────────────────────────────────
// PAYMENT (Razorpay webhook log)
// ─────────────────────────────────────────
model Payment {
  id                  String        @id @default(cuid())
  subscriptionId      String
  subscription        Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  razorpayPaymentId   String        @unique  // pay_xxxxxxxxxx
  amount              Int                    // paise mein (9900 = ₹99)
  currency            String        @default("INR")
  status              PaymentStatus

  paidAt              DateTime?
  createdAt           DateTime      @default(now())
}

enum PaymentStatus {
  CAPTURED   // success
  FAILED
  REFUNDED
}